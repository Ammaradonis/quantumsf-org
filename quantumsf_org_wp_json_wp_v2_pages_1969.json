09-1.jpg?w=2304&amp;ssl=1 2304w\\\" sizes=\\\"auto, (max-width: 768px) 100vw, 768px\\\" \\/><\\/figure>\\n\\n\\n\\n<figure class=\\\"wp-block-image size-large\\\"><img data-recalc-dims=\\\"1\\\" loading=\\\"lazy\\\" decoding=\\\"async\\\" width=\\\"768\\\" height=\\\"745\\\" data-attachment-id=\\\"6266\\\" data-permalink=\\\"https:\\/\\/quantumsf.org\\/kids-martial-arts\\/quarks\\/dsc_0090\\/\\\" data-orig-file=\\\"https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/05\\/DSC_0090.jpeg?fit=3367%2C3264&amp;ssl=1\\\" data-orig-size=\\\"3367,3264\\\" data-comments-opened=\\\"1\\\" data-image-meta=\\\"{&quot;aperture&quot;:&quot;5&quot;,&quot;credit&quot;:&quot;&quot;,&quot;camera&quot;:&quot;NIKON D5100&quot;,&quot;caption&quot;:&quot;&quot;,&quot;created_timestamp&quot;:&quot;1601680517&quot;,&quot;copyright&quot;:&quot;&quot;,&quot;focal_length&quot;:&quot;38&quot;,&quot;iso&quot;:&quot;800&quot;,&quot;shutter_speed&quot;:&quot;0.00125&quot;,&quot;title&quot;:&quot;&quot;,&quot;orientation&quot;:&quot;1&quot;}\\\" data-image-title=\\\"DSC_0090\\\" data-image-description=\\\"\\\" data-image-caption=\\\"\\\" data-large-file=\\\"https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/05\\/DSC_0090.jpeg?fit=768%2C745&amp;ssl=1\\\" data-id=\\\"6266\\\" src=\\\"https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/05\\/DSC_0090.jpeg?resize=768%2C745&#038;ssl=1\\\" alt=\\\"\\\" class=\\\"wp-image-6266\\\" srcset=\\\"https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/05\\/DSC_0090.jpeg?resize=1024%2C993&amp;ssl=1 1024w, https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/05\\/DSC_0090.jpeg?resize=300%2C291&amp;ssl=1 300w, https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/05\\/DSC_0090.jpeg?resize=768%2C745&amp;ssl=1 768w, https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/05\\/DSC_0090.jpeg?resize=1536%2C1489&amp;ssl=1 1536w, https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/05\\/DSC_0090.jpeg?resize=2048%2C1985&amp;ssl=1 2048w, https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/05\\/DSC_0090.jpeg?resize=62%2C60&amp;ssl=1 62w, https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/05\\/DSC_0090.jpeg?w=2304&amp;ssl=1 2304w\\\" sizes=\\\"auto, (max-width: 768px) 100vw, 768px\\\" \\/><\\/figure>\\n<\\/figure>\\n<\\/div><\\/div>\\n\\n\\n\\n<div class=\\\"wp-block-group\\\"><div class=\\\"wp-block-group__inner-container is-layout-flow wp-block-group-is-layout-flow\\\">\\n<h4 class=\\\"wp-block-heading\\\" id=\\\"tuition\\\">Tuition<\\/h4>\\n\\n\\n\\n<p class=\\\"wp-block-paragraph\\\">As with all Quantum classes, the first week of trial classes is FREE! Quantum is a register ed CA 501(c)(3) nonprofit, and our price structure is designed to make classes available to all. As such, we offer sliding scale to every students who needs it. <br><br><strong>Suggested<\\/strong> <strong>monthly dues:<\\/strong> $175 per child. These dues include access to unlimited classes.<br> <strong>Yearly membership fee:<\\/strong> $60 per student.<br> <strong>Uniforms:<\\/strong> $30\\u2013$50<\\/p>\\n<\\/div><\\/div>\\n<\\/div>\\n<\\/div>\\n<\\/div><\\/div>\\n\\n\\n\\n<p class=\\\"wp-block-paragraph\\\"><\\/p>\\n\\n\\n\\n<h4 class=\\\"wp-block-heading\\\" id=\\\"enroll-today\\\">Enroll Today!<\\/h4>\\n\\n\\n\\n<p class=\\\"wp-block-paragraph\\\"><a href=\\\"https:\\/\\/quantumsf.org\\/contact-us\\/\\\">Click here<\\/a> to sign up for a free trial Quarks class and orientation at the Quantum Dojo. <\\/p>\\n\\n\\n\\n<figure class=\\\"wp-block-image size-full is-resized\\\"><img data-recalc-dims=\\\"1\\\" loading=\\\"lazy\\\" decoding=\\\"async\\\" width=\\\"768\\\" height=\\\"505\\\" data-attachment-id=\\\"6398\\\" data-permalink=\\\"https:\\/\\/quantumsf.org\\/kids-martial-arts\\/quarks\\/quantummartialarts_10-12-2019_034-909x1024-1\\/\\\" data-orig-file=\\\"https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/07\\/QuantumMartialArts_10-12-2019_034-909x1024-1.jpeg?fit=909%2C598&amp;ssl=1\\\" data-orig-size=\\\"909,598\\\" data-comments-opened=\\\"1\\\" data-image-meta=\\\"{&quot;aperture&quot;:&quot;0&quot;,&quot;credit&quot;:&quot;&quot;,&quot;camera&quot;:&quot;&quot;,&quot;caption&quot;:&quot;&quot;,&quot;created_timestamp&quot;:&quot;0&quot;,&quot;copyright&quot;:&quot;&quot;,&quot;focal_length&quot;:&quot;0&quot;,&quot;iso&quot;:&quot;0&quot;,&quot;shutter_speed&quot;:&quot;0&quot;,&quot;title&quot;:&quot;&quot;,&quot;orientation&quot;:&quot;1&quot;}\\\" data-image-title=\\\"QuantumMartialArts_10-12-2019_034-909&amp;#215;1024-1\\\" data-image-description=\\\"\\\" data-image-caption=\\\"\\\" data-large-file=\\\"https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/07\\/QuantumMartialArts_10-12-2019_034-909x1024-1.jpeg?fit=768%2C505&amp;ssl=1\\\" src=\\\"https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/07\\/QuantumMartialArts_10-12-2019_034-909x1024-1.jpeg?resize=768%2C505&#038;ssl=1\\\" alt=\\\"\\\" class=\\\"wp-image-6398\\\" srcset=\\\"https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/07\\/QuantumMartialArts_10-12-2019_034-909x1024-1.jpeg?w=909&amp;ssl=1 909w, https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/07\\/QuantumMartialArts_10-12-2019_034-909x1024-1.jpeg?resize=300%2C197&amp;ssl=1 300w, https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/07\\/QuantumMartialArts_10-12-2019_034-909x1024-1.jpeg?resize=768%2C505&amp;ssl=1 768w, https:\\/\\/i0.wp.com\\/quantumsf.org\\/wp-content\\/uploads\\/2021\\/07\\/QuantumMartialArts_10-12-2019_034-909x1024-1.jpeg?resize=91%2C60&amp;ssl=1 91w\\\" sizes=\\\"auto, (max-width: 768px) 100vw, 768px\\\" \\/><figcaption class=\\\"wp-element-caption\\\">Photo by Stephanie Court Toscano. <\\/figcaption><\\/figure>\\n\\n\\n<div class=\\\"wp-block-jetpack-google-calendar\\\"><iframe loading=\\\"lazy\\\" 